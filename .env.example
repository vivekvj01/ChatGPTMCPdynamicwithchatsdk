PORT=8080
APP_BASE_URL=https://your-cloud-run-url

# Shared auth service configuration
SALESFORCE_AUTH_SERVICE_URL=https://your-auth-service.example.com
SALESFORCE_AUTH_SERVICE_SECRET=your_shared_secret
SALESFORCE_AGENT_ID=0XxXXXXXXXXXXXX
SALESFORCE_TENANT_ID=core/your-tenant/your-org-id
SALESFORCE_REGION=us-west-2
SALESFORCE_LOGIN_URL=https://login.salesforce.com
SALESFORCE_AGENT_API_BASE_URL=
SALESFORCE_USE_AUTH_SERVICE_AGENT_QUERY=true

# Optional OpenAI widget generation
OPENAI_API_KEY=
OPENAI_WIDGET_MODEL=gpt-5.4-mini
